# ============================================================
# SOCIALCONNECT — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database — Option A: Individual fields (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_POSTGRES_PASSWORD
DB_NAME=socialconnect

# Database — Option B: Connection string (for Render/Railway/Supabase)
# If DATABASE_URL is set, it takes priority over individual fields above
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=GENERATE_A_RANDOM_64_CHAR_HEX_STRING

# AES Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AES_KEY=GENERATE_A_RANDOM_64_CHAR_HEX_STRING

# Cloudinary (get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=SocialConnect <your_email@gmail.com>

# Server
PORT=5000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
